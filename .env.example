# Sincronización en la nube (OPCIONAL).
# Copia este archivo a ".env.local" y rellena con los datos de tu proyecto de
# Supabase: panel del proyecto -> Project Settings -> API.
#
# La "anon key" es PÚBLICA y segura de usar en el frontend: el acceso a los
# datos lo protege la seguridad por filas (RLS). NO pongas aquí la "service_role".
#
# Si dejas estas variables vacías, la app funciona en modo 100% local.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY


# -------------------------------------------------------------------------
# PLAN PRO / STRIPE  (solo en el SERVIDOR — configúralas en Vercel, NO en el
# frontend). Estas NO llevan el prefijo VITE_ a propósito: así no se exponen
# en el navegador. Las usan las funciones de la carpeta api/.
# -------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...            # id del precio del plan Pro (suscripción)
# STRIPE_WEBHOOK_SECRET=whsec_...      # del endpoint de webhook en Stripe
# SUPABASE_URL=https://TU-PROYECTO.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...        # clave service_role (SECRETA, solo servidor)
