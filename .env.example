# Sincronización en la nube (OPCIONAL).
# Copia este archivo a ".env.local" y rellena con los datos de tu proyecto de
# Supabase: panel del proyecto -> Project Settings -> API.
#
# La "anon key" es PÚBLICA y segura de usar en el frontend: el acceso a los
# datos lo protege la seguridad por filas (RLS). NO pongas aquí la "service_role".
#
# Si dejas estas variables vacías, la app funciona en modo 100% local.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY
